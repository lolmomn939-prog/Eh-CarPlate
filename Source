local function applyLicensePlate(vehicle)
    local body = vehicle:WaitForChild("Body", 10)
    if not body then return end
    
    local plates = body:WaitForChild("LicensePlates", 10)
    if not plates then return end
    for _, side in pairs(plates:GetChildren()) do
        if side.Name == "Front" or side.Name == "Back" then
            local gui = side:FindFirstChild("Gui")
            if gui then
                local label = gui:FindFirstChildOfClass("TextLabel")
                if label then
                    label.Text = CarPlate
                end
            end
        end
    end
end

